# ── LLM provider keys — set at least one ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# ── Model routing (optional overrides) ───────────────────────────────────────
# FAST_MODEL=anthropic:claude-haiku-4-5-20251001
# BALANCED_MODEL=anthropic:claude-sonnet-4-6
# POWERFUL_MODEL=anthropic:claude-opus-4-8

# ── Database (PostgreSQL + pgvector) ─────────────────────────────────────────
# docker-compose overrides this automatically; only set it for local dev
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/qa_platform

# ── Confidence thresholds ────────────────────────────────────────────────────
MIN_CONFIDENCE_FOR_AUTO_PROCEED=0.75
MAX_AMBIGUITIES_FOR_AUTO_PROCEED=3

# ── LLM retry config ─────────────────────────────────────────────────────────
MAX_SKILL_RETRIES=3
SKILL_RETRY_DELAY_SECONDS=1.0
MAX_CONCURRENT_LLM_CALLS=3

# ── Embedding model (must match vector table dimensions) ─────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
