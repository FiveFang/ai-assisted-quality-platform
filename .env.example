ANTHROPIC_API_KEY=sk-ant-...

# Vector DB (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=qa_platform_requirements

# Temporal workflow engine (optional — dev runs without it using in-memory state)
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=qa-platform

# Confidence thresholds
# Below MIN_CONFIDENCE → human review gate triggered
MIN_CONFIDENCE_FOR_AUTO_PROCEED=0.75
MAX_AMBIGUITIES_FOR_AUTO_PROCEED=3

# Retry config for LLM skill calls
MAX_SKILL_RETRIES=3
SKILL_RETRY_DELAY_SECONDS=1.0

# Embedding model (must match Qdrant collection vector size)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Default model tier: fast | balanced | powerful
# fast     = claude-haiku-4-5-20251001
# balanced = claude-sonnet-4-6  (default)
# powerful = claude-opus-4-8
DEFAULT_MODEL_TIER=balanced
